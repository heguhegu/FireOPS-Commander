{
  "entities": {
    "Hazard": {
      "title": "Hazard",
      "description": "Known hazards in a specific district.",
      "type": "object",
      "properties": {
        "location": {
          "type": "string",
          "description": "The district or location name."
        },
        "description": {
          "type": "string",
          "description": "Description of the hazard."
        }
      },
      "required": ["location", "description"]
    },
    "Incident": {
      "title": "Incident",
      "description": "A fire incident triage report.",
      "type": "object",
      "properties": {
        "station_id": {
          "type": "string",
          "description": "The ID of the station reporting."
        },
        "original_report": {
          "type": "string",
          "description": "The raw text report from the dispatcher."
        },
        "triage_report": {
          "type": "object",
          "description": "The structured triage data generated by the agent."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "Server timestamp of the incident."
        }
      },
      "required": ["station_id", "original_report", "triage_report", "timestamp"]
    }
  },
  "firestore": {
    "hazards": {
      "schema": "Hazard",
      "description": "Collection of known hazards."
    },
    "active_incidents": {
      "schema": "Incident",
      "description": "Collection of processed incidents."
    }
  }
}
